{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile containing roles and identification.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "student", "staff"] }
      },
      "required": ["uid", "email", "role"]
    },
    "Student": {
      "title": "Student",
      "description": "Student academic record and metadata",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Registration number" },
        "docId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "department": { "type": "string" },
        "admissionYear": { "type": "number" },
        "level": { "type": "string" },
        "passportURL": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "suspended", "graduated"] },
        "phone": { "type": "string" },
        "gender": { "type": "string", "enum": ["Male", "Female"] },
        "dob": { "type": "string" },
        "bloodGroup": { "type": "string", "enum": ["A+", "A-", "B+", "B-", "AB+", "AB-", "O+", "O-"] },
        "religion": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" },
        "userId": { "type": "string", "description": "Owner user mapping" }
      },
      "required": ["id", "docId", "name", "email", "department", "admissionYear", "level", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/students/{studentId}": {
      "schema": { "$ref": "#/entities/Student" },
      "description": "Student details"
    }
  }
}
