rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isAdmin() {
      return isSignedIn() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // --- User Profiles ---
    match /users/{uid} {
      allow get: if isOwner(uid) || isAdmin();
      allow list: if isAdmin();
      
      // Allow initial profile creation if user signs up
      allow create: if isOwner(uid) && 
                      incoming().role == 'student' && 
                      incoming().keys().hasAll(['uid', 'email', 'role']) &&
                      incoming().keys().size() <= 6; // uid, email, displayName, role, photoURL, studentId
      
      allow update: if (isAdmin() || (isOwner(uid) && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL'])));
      allow delete: if isAdmin();
    }

    // --- Students ---
    match /students/{docId} {
      // Verification logic: Anyone can 'get' a student record if they know the document ID (QR code link)
      // but we limit what they can see if not admin/owner. 
      // Actually, Firestore rules are all-or-nothing for a document.
      // So 'get' is allowed for verification, but only for active students.
      allow get: if isSignedIn(); 
      
      // Admin can list all students
      allow list: if isAdmin();

      // Only admins can create, update, delete student records
      allow create: if isAdmin() && isValidStudent(incoming());
      
      allow update: if isAdmin() && isValidStudent(incoming());
      
      allow delete: if isAdmin();
    }

    function isValidStudent(data) {
      return data.keys().hasAll(['id', 'name', 'email', 'department', 'level', 'passportURL', 'createdAt', 'updatedAt', 'status']) &&
             data.id is string && data.id.size() <= 20 &&
             data.name is string && data.name.size() <= 100 &&
             data.email is string &&
             data.department is string &&
             data.level is string &&
             data.passportURL is string &&
             data.status in ['active', 'suspended', 'graduated'] &&
             data.createdAt is number &&
             data.updatedAt is number;
    }
  }
}
